{
  "extends": [
    "development"
  ],
  "hints": {
    "compat-api/css": [
      "default",
      {
        "ignore": [
          "text-wrap",
          "text-wrap: balance",
          "text-wrap: pretty"
        ]
      }
    ]
  },
  "browserslist": [
    "defaults",
    "not ie 11",
    "not and_ff <= 146",
    "not edge <= 143",
    "not firefox <= 146",
    "not samsung <= 29"
  ]
}